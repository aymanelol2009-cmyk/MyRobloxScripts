repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Project Delta | EDEN-XANDER",
    LoadingTitle = "Global Entity ESP",
    LoadingSubtitle = "Fix Bandits & Bases",
    ConfigurationSaving = { Enabled = true, FolderName = "EDEN_Delta", FileName = "Config" }
})

local VisualTab = Window:CreateTab("Visual", 4483362458)

local Settings = {
    PlayersESP = false,
    NPCESP = false,
    DeadESP = false,
    MaxDistance = 5000,
}

local function CleanESP()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v.Name == "EDEN_Highlight" or v.Name == "EDEN_Billboard" then
            v:Destroy()
        end
    end
end

VisualTab:CreateSection("ESP Control")
VisualTab:CreateToggle({Name = "Players ESP", CurrentValue = false, Callback = function(v) Settings.PlayersESP = v if not v then CleanESP() end end})
VisualTab:CreateToggle({Name = "NPC / Bandits ESP", CurrentValue = false, Callback = function(v) Settings.NPCESP = v if not v then CleanESP() end end})
VisualTab:CreateToggle({Name = "Dead Players ESP", CurrentValue = false, Callback = function(v) Settings.DeadESP = v if not v then CleanESP() end end})

VisualTab:CreateSlider({
    Name = "Render Distance",
    Range = {500, 5000},
    Increment = 100,
    CurrentValue = 5000,
    Callback = function(v) Settings.MaxDistance = v end
})

local function CreateESP(model, color, displayText)
    if model:FindFirstChild("EDEN_Highlight") then return end

    local hl = Instance.new("Highlight")
    hl.Name = "EDEN_Highlight"
    hl.Adornee = model
    hl.FillColor = color
    hl.FillTransparency = 0.5
    hl.OutlineColor = Color3.new(1,1,1)
    hl.Parent = model

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "EDEN_Billboard"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 100, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Parent = model

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.TextColor3 = color
    label.Font = Enum.Font.GothamBold
    label.TextSize = 14
    label.Text = displayText
    label.Parent = billboard

    task.spawn(function()
        while billboard and billboard.Parent do
            if not (Settings.PlayersESP or Settings.NPCESP or Settings.DeadESP) then break end
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head")
                if root then
                    local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - root.Position).Magnitude)
                    label.Text = displayText .. " [" .. dist .. "m]"
                    local isVisible = dist <= Settings.MaxDistance
                    hl.Enabled = isVisible
                    billboard.Enabled = isVisible
                else
                    break -- Si le root disparait (cadavre supprimé), on stop
                end
            end
            task.wait(0.5)
        end
        if hl then hl:Destroy() end
        if billboard then billboard:Destroy() end
    end)
end

-- SCANNEUR INTELLIGENT (Cherche dans les sous-dossiers pour les Bandits)
task.spawn(function()
    while task.wait(1.5) do -- Scan un peu plus lent pour garder tes 200 FPS
        if Settings.PlayersESP or Settings.NPCESP or Settings.DeadESP then
            -- On utilise GetDescendants mais avec des filtres pour ne pas lag
            for _, model in pairs(Workspace:GetDescendants()) do
                if model:IsA("Model") and model ~= LocalPlayer.Character then
                    
                    local hum = model:FindFirstChild("Humanoid")
                    if hum then
                        local isPlayer = Players:GetPlayerFromCharacter(model) ~= nil
                        local isDead = hum.Health <= 0
                        
                        if isDead and Settings.DeadESP then
                            CreateESP(model, Color3.fromRGB(150, 150, 150), "DEAD")
                        elseif not isDead then
                            if isPlayer and Settings.PlayersESP then
                                CreateESP(model, Color3.fromRGB(255, 0, 0), "PLAYER")
                            elseif not isPlayer and Settings.NPCESP then
                                -- C'est ici que ça détecte les bandits des bases
                                CreateESP(model, Color3.fromRGB(255, 165, 0), "BANDIT/NPC")
                            end
                        end
                    end
                end
            end
        end
    end
end)

Rayfield:Notify({Title = "EDEN-XANDER", Content = "V4 GLOBAL SCAN READY ✅", Duration = 5})
